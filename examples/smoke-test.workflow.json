      "id": "resolve-space",
      "name": "Resolve space (list drives)",
      "notesInFlow": true,
      "notes": "Calls /graph/v1.0/me/drives via the OpenCloud node so we can pick the personal drive without hardcoding any drive id. Works against any backend.",
      "credentials": {
        "openCloudApi": {
          "id": "REPLACE_WITH_YOUR_CREDENTIAL_ID"
        }
      }
