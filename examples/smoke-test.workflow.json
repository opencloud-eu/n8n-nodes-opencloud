    {
      "parameters": {
        "jsCode": "// Aggregates each upstream OpenCloud step's output and reports pass/fail per step.\n// A step that returned `{ error: '...' }` (continueOnFail) is reported as failed,\n// otherwise pass. Surface the actual error message AND the server-detail\n// description (e.g. password complexity hints) for any step that failed.\nconst steps = [\n\t['0. Cleanup any pre-existing /n8n-smoke', true],\n\t['1. Create /n8n-smoke', false],\n\t['3. Upload hello.txt', false],\n\t['4. List /n8n-smoke', false],\n\t['5. Download hello.txt', false],\n\t['6. Create archive subfolder', false],\n\t['7. Copy \u2192 archive/copy.txt', false],\n\t['8. Rename \u2192 renamed.txt', false],\n\t['9. Create share link', false],\n\t['10. Delete hello.txt', false],\n\t['11. Delete /n8n-smoke (cleanup)', false],\n];\n\nconst results = [];\nlet failures = 0;\n\nfor (const [name, ignoreError] of steps) {\n\ttry {\n\t\tconst out = $(name).first()?.json ?? {};\n\t\tconst error = typeof out.error === 'string' ? out.error : null;\n\t\tconst description = typeof out.errorDescription === 'string' ? out.errorDescription : null;\n\t\tconst pass = !error;\n\t\tif (!pass && !ignoreError) failures++;\n\t\tresults.push({\n\t\t\tstep: name,\n\t\t\tpass,\n\t\t\t...(error ? { error } : {}),\n\t\t\t...(description ? { errorDescription: description } : {}),\n\t\t\t...(ignoreError && error ? { ignored: true } : {}),\n\t\t});\n\t} catch (e) {\n\t\tresults.push({ step: name, pass: false, error: 'no upstream output: ' + e.message });\n\t\tif (!ignoreError) failures++;\n\t}\n}\n\nreturn [{ json: { failures, totalCounted: steps.filter(([, ignore]) => !ignore).length, results } }];"
      },
