    {
      "parameters": {
        "jsCode": "// Pick the personal drive from the Space:List output, then expose the\n// fixed test inputs (root folder + test file name). All downstream nodes\n// reference these via $(\"Config\").first().json.\nconst inputs = $input.all().map((it) => it.json);\n// If the upstream Space:List had continueOnFail enabled and the call to\n// OpenCloud failed, n8n substitutes { error, errorDescription } for the\n// drive list. Surface that root cause instead of stringifying nulls.\nconst upstream = inputs.find((i) => i && typeof i.error === \"string\");\nif (upstream) {\n\tconst detail = upstream.errorDescription ? upstream.error + \" \\u2014 \" + upstream.errorDescription : upstream.error;\n\tthrow new Error(\"Cannot resolve a personal drive: the upstream Resolve-space step failed: \" + detail);\n}\nconst personal = inputs.find((d) => d && d.driveType === \"personal\");\nif (!personal) {\n\tconst summary = inputs.length === 0 ? \"(no drives returned)\" : inputs.map((d) => (d && d.name ? d.name : \"<no-name>\") + \"/\" + (d && d.driveType ? d.driveType : \"<no-type>\")).join(\", \");\n\tthrow new Error(\"No personal drive in /me/drives response. Drives received: \" + summary + \". Verify the credential authenticates as a user that has a personal drive provisioned.\");\n}\nreturn [{ json: { spaceId: personal.id, rootFolder: \"/n8n-smoke\", fileName: \"hello.txt\" } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        600,
        300
